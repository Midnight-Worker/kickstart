BoxLayout:
    orientation: "vertical"
    padding: 30
    spacing: 20

    Label:
        id: ausgabe
        text: app.text
        font_size: 32

    Button:
        text: "KV ruft Python"
        font_size: 24
        on_press: app.kv_ruft_python()

    Button:
        text: "Python ruft KV"
        font_size: 24
        on_press: app.python_ruft_kv()
